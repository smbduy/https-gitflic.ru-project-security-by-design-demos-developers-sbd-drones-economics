# Настройки инфраструктуры брокера
BROKER_TYPE=kafka

KAFKA_PORT=9092
KAFKA_INTERNAL_PORT=29092
MQTT_PORT=1883

# Админ — всегда есть в Kafka. Используйте для тестов и для сервисов без своих кредов.
ADMIN_USER=admin
ADMIN_PASSWORD=admin_secret_123

# Опционально: отдельные пользователи для компонентов. Если заданы — добавляются в Kafka
# и контейнеры могут подключаться под своими кредами (BROKER_USER/BROKER_PASSWORD в compose).
#COMPONENT_USER_A=
#COMPONENT_PASSWORD_A=
#COMPONENT_USER_B=
#COMPONENT_PASSWORD_B=

DOCKER_NETWORK=drones_net

# Fabric Ledger: true/false
ENABLE_FABRIC=false
FABRIC_PROXY_PORT=3000
