{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["drone_id"],
  "properties": {
    "drone_id": {
      "type": "string",
      "pattern": "^drone_[0-9]{3,4}$"
    },
    "action": {
      "type": "string"
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "reply_to": {
      "type": "string",
      "minLength": 1
    }
  }
}
