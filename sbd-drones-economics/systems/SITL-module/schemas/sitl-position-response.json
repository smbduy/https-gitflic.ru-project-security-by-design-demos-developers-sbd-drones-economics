{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["lat", "lon", "alt"],
  "properties": {
    "lat": {
      "type": "number"
    },
    "lon": {
      "type": "number"
    },
    "alt": {
      "type": "number"
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    }
  }
}
