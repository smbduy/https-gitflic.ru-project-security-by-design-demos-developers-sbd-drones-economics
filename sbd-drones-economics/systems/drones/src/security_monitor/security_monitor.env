# Security monitor defaults merged by prepare_system.py as SECURITY_MONITOR_*.
# ${SYSTEM_NAME} is expanded at prepare time to TOPIC_VERSION.SYSTEM_NAME.INSTANCE_ID (prefix only).
BROKER_USER=<your-user>
BROKER_PASSWORD=<your-password>
SECURITY_POLICIES=[{"sender":"limiter","topic":"${SYSTEM_NAME}.navigation","action":"get_state"},{"sender":"limiter","topic":"${SYSTEM_NAME}.telemetry","action":"get_state"},{"sender":"limiter","topic":"${SYSTEM_NAME}.journal","action":"LOG_EVENT"},{"sender":"limiter","topic":"${SYSTEM_NAME}.emergency","action":"limiter_event"},{"sender":"mission_handler","topic":"${SYSTEM_NAME}.autopilot","action":"mission_load"},{"sender":"mission_handler","topic":"${SYSTEM_NAME}.limiter","action":"mission_load"},{"sender":"mission_handler","topic":"${SYSTEM_NAME}.journal","action":"LOG_EVENT"},{"sender":"autopilot","topic":"${SYSTEM_NAME}.navigation","action":"get_state"},{"sender":"autopilot","topic":"${SYSTEM_NAME}.motors","action":"SET_TARGET"},{"sender":"autopilot","topic":"${SYSTEM_NAME}.cargo","action":"OPEN"},{"sender":"autopilot","topic":"${SYSTEM_NAME}.cargo","action":"CLOSE"},{"sender":"autopilot","topic":"${SYSTEM_NAME}.journal","action":"LOG_EVENT"},{"sender":"emergency","topic":"${SYSTEM_NAME}.motors","action":"LAND"},{"sender":"emergency","topic":"${SYSTEM_NAME}.cargo","action":"CLOSE"},{"sender":"emergency","topic":"${SYSTEM_NAME}.journal","action":"LOG_EVENT"},{"sender":"emergency","topic":"${SYSTEM_NAME}.security_monitor","action":"isolation_status"},{"sender":"telemetry","topic":"${SYSTEM_NAME}.motors","action":"get_state"},{"sender":"telemetry","topic":"${SYSTEM_NAME}.cargo","action":"get_state"},{"sender":"cargo","topic":"${SYSTEM_NAME}.journal","action":"LOG_EVENT"},{"sender":"navigation","topic":"${SYSTEM_NAME}.journal","action":"LOG_EVENT"},{"sender":"platform","topic":"${SYSTEM_NAME}.mission_handler","action":"LOAD_MISSION"},{"sender":"platform","topic":"${SYSTEM_NAME}.mission_handler","action":"VALIDATE_ONLY"}]