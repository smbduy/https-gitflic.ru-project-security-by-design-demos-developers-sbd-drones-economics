COMPONENT_ID=system_monitor

# Веб-интерфейс и API (1 = включено, 0 = только MQTT)
SYSTEM_MONITOR_HTTP=1
SYSTEM_MONITOR_HTTP_PORT=8090

# Опрос телеметрии через МБ (таймаут ≥ SECURITY_MONITOR proxy, обычно 10s → здесь 15s)
SYSTEM_MONITOR_TELEMETRY_POLL_S=1.0
SYSTEM_MONITOR_TELEMETRY_TIMEOUT_S=15.0

# Буфер перехваченных log_event с топика журнала
SYSTEM_MONITOR_JOURNAL_BUFFER=2000
