SYSTEM_NAME=components
COMPONENT_ID=limiter
BROKER_USER=limiter
BROKER_PASSWORD=limiter_secret

# Параметры ограничителя (env-driven)
LIMITER_CONTROL_INTERVAL_S=0.5
LIMITER_NAV_POLL_INTERVAL_S=0.5
LIMITER_TELEMETRY_POLL_INTERVAL_S=1.0
LIMITER_REQUEST_TIMEOUT_S=2.0

# Пороги
LIMITER_MAX_DISTANCE_FROM_PATH_M=10.0
LIMITER_MAX_ALT_DEVIATION_M=3.0

# Action'ы для snapshot-запросов
LIMITER_NAVIGATION_GET_STATE_ACTION=get_state
LIMITER_TELEMETRY_GET_STATE_ACTION=get_state

