SYSTEM_NAME=Agrodron
COMPONENT_ID=security_monitor
BROKER_USER=security_monitor
BROKER_PASSWORD=security_monitor_secret
POLICY_ADMIN_SENDER=security_monitor_admin

# Полный актуальный JSON политик — см. рядом файл `.env` (ключ SECURITY_POLICIES).
# В шаблонах sender/topic вида "${SYSTEM_NAME}.<компонент>" при `make prepare` в корне системы
# `${SYSTEM_NAME}` заменяется на v1.<SYSTEM_NAME>.<INSTANCE_ID> (тот же префикс, что даёт topic_for()).
# Внешние топики: ${ORVD_TOPIC}, ${NUS_TOPIC}, ${DRONEPORT_TOPIC}, ${SITL_*}, sitl-drone-home и т.д.

# Таймаут реального request к целевому компоненту внутри МБ
SECURITY_MONITOR_PROXY_REQUEST_TIMEOUT_S=10.0
